# CyberShield OSS Configuration
# Copy this file to .env and fill in your values

# Required for AI features (explanation pipeline & security tutor)
ANTHROPIC_API_KEY=your_api_key_here

# Logging level (DEBUG, INFO, WARNING, ERROR)
CYBERSHIELD_LOG_LEVEL=INFO

# Maximum concurrent HTTP requests during scanning
CYBERSHIELD_MAX_CONCURRENT=5

# HTTP request timeout in seconds
CYBERSHIELD_TIMEOUT=30

# Report output directory
CYBERSHIELD_REPORT_DIR=./reports

# Maximum crawl depth
CYBERSHIELD_MAX_DEPTH=3

# Maximum URLs to scan
CYBERSHIELD_MAX_URLS=50

# Claude model to use
CYBERSHIELD_AI_MODEL=claude-sonnet-4-20250514

# Maximum tokens for AI responses
CYBERSHIELD_AI_MAX_TOKENS=1024

# AI temperature (0.0 = deterministic, 1.0 = creative)
CYBERSHIELD_AI_TEMPERATURE=0.3
